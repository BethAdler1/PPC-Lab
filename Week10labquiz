public class Week10_labs
{
    public static void main(String[] args)
	{
        List<String> fruit = Arrays.asList("cherry","banana","berry","apple","cherry","kiwi","fig","date","lemon","honeydew","cherry","elderberry","apple","banana","grape");

		// Collect elements into a Set
        Set <String> uniqueFruit = fruit.stream().collect(Collectors.toSet());
        System.out.println("Unique fruit: " + uniqueFruit + "\n");

        // Collect the fruit into groups based on their first character
        Map<Character, List<String>> fruitByFirstChar = fruit.stream().collect(Collectors.groupingBy(s -> s.charAt(0)));
        System.out.println("Fruit grouped by first character: " + fruitByFirstChar+ "\n");

		// Group fruit by the length of the name
        Map<Integer, List<String>> fruitByLength = fruit.stream().collect(Collectors.groupingBy(String::length));
        System.out.println("Fruit grouped by length: " + fruitByLength + "\n" );


		//Collect the fruit that has erry in it
        List<String> fruitWithErry = fruit.stream().filter(s -> s.contains("erry")).collect(Collectors.toList());
        System.out.println("Fruit with 'erry': " + fruitWithErry+ "\n");

		//Create a partition of fruit based on if it contains erry
        Map<Boolean, List<String>> partitionedFruit = fruit.stream().collect(Collectors.partitioningBy(s -> s.contains("erry")));
        System.out.println("Partitioned fruit based on if it contains 'erry': " + partitionedFruit+ "\n");
		
        //collect the fruit that has 5 or less symbols
        List<String> smallFruit = fruit.stream().filter(s -> s.length() <= 5).collect(Collectors.toList());
        System.out.println("Small fruit: " + smallFruit+ "\n");
		
        //find the total number of symbols in all the fruit stored
        int totalSymbols = fruit.stream().collect(Collectors.summingInt(String::length));
        System.out.println("Total number of symbols in all fruit: " + totalSymbols+ "\n");

		List<Integer> data = Arrays.asList(87, 23, 45, 100, 6, 78, 92, 44, 13, 56, 34, 99, 82, 19, 1012, 78, 45, 90, 23, 56, 78, 100, 3, 43, 67, 89, 21, 34, 10);
        

        // Partition data based on if >=50
        Map<Boolean, List<Integer>> partitionedData = data.stream().collect(Collectors.partitioningBy(i-> i >= 50));
        System.out.println("Data partitioned by >=50: " + partitionedData+ "\n");

		//divide data into groups based on the remainder when divided by 7
        System.out.println("Data by remainder when divided by 7:");
        Map<Integer, List<Integer>> dataByRemainder = data.stream().collect(Collectors.groupingBy(i -> i % 7));//group by the remainder when divided by 7
        System.out.println(dataByRemainder+ "\n");

		//find the sum of the data
        int sum = data.stream().collect(Collectors.summingInt(Integer::intValue));//summingInt collector to sum the integers
        System.out.println("Sum of data: " + sum+   "\n");


		//collect the unique values
        Set<Integer> uniqueData = data.stream().collect(Collectors.toSet());//collect to a set to get unique values
        System.out.println("Unique data: " + uniqueData+ "\n");

        //compute the cube of each values
        List<Integer> cubes = data.stream().map(i -> i * i * i).collect(Collectors.toList());//map to cube each value, then collect to list
        System.out.println("Cubes of data: " + cubes+ "\n");

		//find the sum of the cubes of each value
        int sumOfCubes = cubes.stream().collect(Collectors.summingInt(Integer::intValue));//sum the cubes using summingInt collector
        System.out.println("Sum of cubes: " + sumOfCubes+ "\n");

		//increase the value of each element by 5
        List<Integer> increasedData = data.stream().map(i -> i + 5).collect(Collectors.toList());//map to increase each value by 5, then collect to list
        System.out.println("Data increased by 5: " + increasedData+ "\n");

		//compute the cube of the even values
        List<Integer> evenCubes = data.stream().filter(i -> i % 2 == 0).map(i -> i * i * i).collect(Collectors.toList());//filter for even values, then map to cube, then collect to list
        System.out.println("Cubes of even values: " + evenCubes+ "\n");
    

   }
}
